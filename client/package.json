{
    "name": "tienxin-productivity-assistant",
    "version": "26.03.16.2",
    "description": "添心生產力助手 - 智能工作追蹤與提醒系統 (V2 Immutable Core)",
    "main": "main.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/nephi4377/TAUpdata.git"
    },
    "author": "添心室內裝修設計",
    "license": "UNLICENSED",
    "private": true,
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "eslint": "^8.46.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-node": "^11.1.0",
        "husky": "^8.0.0",
        "lint-staged": "^13.1.0",
        "prettier": "^2.8.8"
    },
    "dependencies": {
        "active-win": "^8.1.0",
        "adm-zip": "^0.5.16",
        "axios": "^1.13.6",
        "electron-log": "^5.4.3",
        "electron-store": "^8.1.0",
        "electron-updater": "^6.7.3",
        "firebase": "^12.10.0",
        "fs-extra": "^11.1.1",
        "node-ical": "^0.25.4",
        "node-schedule": "^2.1.1",
        "sql.js": "^1.9.0",
        "uuid": "^9.0.0"
    },
    "build": {
        "appId": "com.tienxin.productivity-assistant",
        "productName": "TienxinAssistant",
        "asar": true,
        "compression": "maximum",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!dist/*",
            "!.cache/*",
            "!*.log",
            "!debug_log.txt",
            "!test_verification.js",
            "!verify_*.js",
            "!data/activities.db",
            "!.git/*",
            "!.vscode/*"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": true,
            "allowToChangeInstallationDirectory": false,
            "shortcutName": "添心生產力助手",
            "installerLanguages": [
                "zh_TW"
            ],
            "language": "1028",
            "deleteAppDataOnUninstall": false
        }
    },
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder",
        "build:win": "electron-builder --win --x64",
        "prepare": "husky install",
        "lint": "eslint \"**/*.js\" --fix",
        "format": "prettier --write \"**/*.{js,json,md}\""
    },
    "lint-staged": {
        "**/*.js": [
            "eslint --fix",
            "git add"
        ]
    }
}